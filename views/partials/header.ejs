<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav>
    <a href="/" class="nav-brand">🔒 The Clubhouse</a>
    <div class="nav-links">
      <% if (user) { %>
        <span class="nav-user">
          Hi, <%= user.first_name %>
          <% if (user.is_admin) { %><span class="badge admin">Admin</span>
          <% } else if (user.is_member) { %><span class="badge member">Member</span>
          <% } %>
        </span>
        <a href="/new-message">+ New Message</a>
        <% if (!user.is_member) { %>
          <a href="/join">Join Club</a>
        <% } %>
        <a href="/log-out">Log Out</a>
      <% } else { %>
        <a href="/sign-up">Sign Up</a>
        <a href="/log-in">Log In</a>
      <% } %>
    </div>
  </nav>

  <main>
